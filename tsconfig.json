{
    "compilerOptions": {
        "target": "ES6",
        "module": "commonjs",
        "lib": [
            "DOM",
            "ES6",
            "ES2016"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": [
        "src/**/*"
    ]
}